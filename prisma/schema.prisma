generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISPATCHER
  DRIVER
  ACCOUNTANT
}

enum DriverStatus {
  AVAILABLE
  EN_ROUTE
  AT_RECEIVER
  OFF_DUTY
}

enum TrailerType {
  DRY_VAN
  REEFER
  FLATBED
}

enum EquipmentStatus {
  ACTIVE
  IN_SHOP
  OUT_OF_SERVICE
}

enum LoadStatus {
  COVERED
  PREBOOK
  AT_SHIPPER
  EN_ROUTE
  AT_RECEIVER
  DELIVERED
  CANCELLED
}

enum DocumentType {
  BOL
  RATE_CONFIRMATION
  POD
}

enum InvoiceStatus {
  PENDING
  ISSUED
  PAID
  OVERDUE
  VOID
}

enum NotificationType {
  LOAD_OVERDUE
  DRIVER_CHECKIN
  ETA_ALERT
  LOAD_ASSIGNED
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  REMOVED
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String
  fullName       String
  phone          String?
  role           UserRole
  isActive       Boolean        @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  driverProfile  Driver?
  createdLoads   Load[]         @relation("LoadCreatedBy")
  notifications  Notification[]
  uploadedDocs   Document[]     @relation("DocumentUploadedBy")
  statusEvents   LoadStatusEvent[] @relation("StatusEventCreatedBy")
  auditLogs      AuditLog[]

  @@index([role])
  @@index([isActive])
}

model Driver {
  id                    String              @id @default(cuid())
  userId                String              @unique
  licenseNumber         String
  licenseState          String
  licenseExpiry         DateTime?
  eldHoursRemaining     Decimal?            @db.Decimal(5, 2)
  currentStatus         DriverStatus        @default(AVAILABLE)
  currentLocationId     String?
  hiredAt               DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentLocation       Location?           @relation("DriverCurrentLocation", fields: [currentLocationId], references: [id], onDelete: SetNull)
  assignments           LoadAssignment[]
  locationUpdates       DriverLocationUpdate[]

  @@index([currentStatus])
  @@index([currentLocationId])
  @@index([licenseNumber])
}

model Truck {
  id                  String              @id @default(cuid())
  unitNumber          String              @unique
  vin                 String?             @unique
  make                String?
  model               String?
  year                Int?
  plateNumber         String?
  state               String?
  status              EquipmentStatus     @default(ACTIVE)
  odometer            Int?
  maintenanceDueDate  DateTime?
  insuranceExpiry     DateTime?
  registrationExpiry  DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  assignments         LoadAssignment[]
  maintenanceRecords  MaintenanceRecord[]

  @@index([status])
  @@index([unitNumber])
}

model Trailer {
  id                  String              @id @default(cuid())
  trailerNumber       String              @unique
  type                TrailerType
  vin                 String?             @unique
  plateNumber         String?
  state               String?
  status              EquipmentStatus     @default(ACTIVE)
  maintenanceDueDate  DateTime?
  insuranceExpiry     DateTime?
  registrationExpiry  DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  assignments         LoadAssignment[]
  maintenanceRecords  MaintenanceRecord[]

  @@index([type])
  @@index([status])
  @@index([trailerNumber])
}

model Broker {
  id             String     @id @default(cuid())
  name           String
  mcNumber       String?
  dotNumber      String?
  email          String?
  phone          String?
  address1       String?
  address2       String?
  city           String?
  state          String?
  zipCode        String?
  notes          String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  loads          Load[]

  @@unique([name, phone])
  @@index([name])
  @@index([isActive])
}

model Load {
  id                   String             @id @default(cuid())
  loadNumber           String             @unique
  referenceNumber      String?
  brokerId             String?
  rate                 Decimal            @db.Decimal(10, 2)
  revenue              Decimal?           @db.Decimal(10, 2)
  driverPayment        Decimal?           @db.Decimal(10, 2)
  fuelCost             Decimal?           @db.Decimal(10, 2)
  otherExpense         Decimal?           @db.Decimal(10, 2)
  miles                Int?
  status               LoadStatus         @default(PREBOOK)
  pickupLocationId     String
  deliveryLocationId   String
  currentLocationId    String?
  pickupDate           DateTime
  deliveryDate         DateTime?
  eta                  DateTime?
  notes                String?
  customerReference    String?
  invoiceStatus        InvoiceStatus      @default(PENDING)
  isOverdue            Boolean            @default(false)
  deliveredAt          DateTime?
  cancelledAt          DateTime?
  createdById          String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  broker               Broker?            @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  pickupLocation       Location           @relation("PickupLocation", fields: [pickupLocationId], references: [id], onDelete: Restrict)
  deliveryLocation     Location           @relation("DeliveryLocation", fields: [deliveryLocationId], references: [id], onDelete: Restrict)
  currentLocation      Location?          @relation("CurrentLoadLocation", fields: [currentLocationId], references: [id], onDelete: SetNull)
  createdBy            User               @relation("LoadCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  stops                LoadStop[]
  assignments          LoadAssignment[]
  documents            Document[]
  invoices             Invoice[]
  statusHistory        LoadStatusEvent[]
  checkCalls           CheckCall[]
  financials           LoadFinancial?

  @@index([status])
  @@index([brokerId])
  @@index([pickupDate])
  @@index([deliveryDate])
  @@index([eta])
  @@index([invoiceStatus])
  @@index([isOverdue])
}

model LoadStop {
  id                  String      @id @default(cuid())
  loadId              String
  type                StopType
  sequence            Int
  locationId          String
  appointmentDate     DateTime?
  actualArrivalAt     DateTime?
  actualDepartureAt   DateTime?
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  load                Load        @relation(fields: [loadId], references: [id], onDelete: Cascade)
  location            Location    @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@unique([loadId, sequence])
  @@index([loadId, type])
  @@index([locationId])
}

enum StopType {
  PICKUP
  DELIVERY
  STOP_OFF
}

model LoadAssignment {
  id                  String            @id @default(cuid())
  loadId              String
  driverId            String?
  truckId             String?
  trailerId           String?
  assignedAt          DateTime          @default(now())
  unassignedAt        DateTime?
  status              AssignmentStatus  @default(ACTIVE)
  notes               String?

  load                Load              @relation(fields: [loadId], references: [id], onDelete: Cascade)
  driver              Driver?           @relation(fields: [driverId], references: [id], onDelete: SetNull)
  truck               Truck?            @relation(fields: [truckId], references: [id], onDelete: SetNull)
  trailer             Trailer?          @relation(fields: [trailerId], references: [id], onDelete: SetNull)

  @@index([loadId, status])
  @@index([driverId, status])
  @@index([truckId, status])
  @@index([trailerId, status])
}

model Location {
  id                    String                 @id @default(cuid())
  name                  String?
  address1              String
  address2              String?
  city                  String
  state                 String
  zipCode               String?
  country               String                 @default("US")
  latitude              Decimal?               @db.Decimal(9, 6)
  longitude             Decimal?               @db.Decimal(9, 6)
  geohash               String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  pickupLoads           Load[]                 @relation("PickupLocation")
  deliveryLoads         Load[]                 @relation("DeliveryLocation")
  currentLoads          Load[]                 @relation("CurrentLoadLocation")
  currentDrivers        Driver[]               @relation("DriverCurrentLocation")
  stopLoads             LoadStop[]
  driverLocationUpdates DriverLocationUpdate[]

  @@index([city, state])
  @@index([latitude, longitude])
  @@index([geohash])
}

model Document {
  id             String        @id @default(cuid())
  loadId         String
  type           DocumentType
  fileName       String
  fileKey        String        @unique
  fileUrl        String
  mimeType       String?
  fileSize       Int?
  uploadedById   String
  createdAt      DateTime      @default(now())

  load           Load          @relation(fields: [loadId], references: [id], onDelete: Cascade)
  uploadedBy     User          @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([loadId, type])
  @@index([uploadedById])
}

model Invoice {
  id             String         @id @default(cuid())
  loadId         String
  invoiceNumber  String         @unique
  amount         Decimal        @db.Decimal(10, 2)
  status         InvoiceStatus  @default(PENDING)
  issuedAt       DateTime?
  dueAt          DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  load           Load           @relation(fields: [loadId], references: [id], onDelete: Cascade)

  @@index([loadId])
  @@index([status])
  @@index([dueAt])
}

model LoadFinancial {
  id             String      @id @default(cuid())
  loadId         String      @unique
  revenue        Decimal     @db.Decimal(10, 2)
  driverPayment  Decimal     @default(0) @db.Decimal(10, 2)
  fuelCost       Decimal     @default(0) @db.Decimal(10, 2)
  lumperFee      Decimal     @default(0) @db.Decimal(10, 2)
  detentionFee   Decimal     @default(0) @db.Decimal(10, 2)
  otherExpense   Decimal     @default(0) @db.Decimal(10, 2)
  profit         Decimal     @default(0) @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  load           Load        @relation(fields: [loadId], references: [id], onDelete: Cascade)
}

model LoadStatusEvent {
  id             String      @id @default(cuid())
  loadId         String
  status         LoadStatus
  note           String?
  createdById    String?
  createdAt      DateTime    @default(now())

  load           Load        @relation(fields: [loadId], references: [id], onDelete: Cascade)
  createdBy      User?       @relation("StatusEventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([loadId, createdAt])
  @@index([status])
}

model DriverLocationUpdate {
  id             String      @id @default(cuid())
  driverId       String
  locationId     String?
  latitude       Decimal?    @db.Decimal(9, 6)
  longitude      Decimal?    @db.Decimal(9, 6)
  speedMph       Decimal?    @db.Decimal(5, 2)
  heading        Int?
  source         String?
  recordedAt     DateTime    @default(now())

  driver         Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  location       Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([driverId, recordedAt])
  @@index([latitude, longitude])
}

model CheckCall {
  id             String      @id @default(cuid())
  loadId         String
  driverId       String?
  note           String
  eta            DateTime?
  locationText   String?
  createdAt      DateTime    @default(now())

  load           Load        @relation(fields: [loadId], references: [id], onDelete: Cascade)
  driver         Driver?     @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([loadId, createdAt])
  @@index([driverId])
}

model MaintenanceRecord {
  id             String      @id @default(cuid())
  truckId        String?
  trailerId      String?
  serviceType    String
  description    String?
  cost           Decimal?    @db.Decimal(10, 2)
  serviceDate    DateTime
  nextDueDate    DateTime?
  createdAt      DateTime    @default(now())

  truck          Truck?      @relation(fields: [truckId], references: [id], onDelete: Cascade)
  trailer        Trailer?    @relation(fields: [trailerId], references: [id], onDelete: Cascade)

  @@index([truckId, serviceDate])
  @@index([trailerId, serviceDate])
}

model Notification {
  id             String             @id @default(cuid())
  userId         String
  type           NotificationType
  title          String
  message        String
  metadata       Json?
  isRead         Boolean            @default(false)
  createdAt      DateTime           @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
}

model RefreshToken {
  id             String      @id @default(cuid())
  userId         String
  tokenHash      String      @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime    @default(now())

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id             String      @id @default(cuid())
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
