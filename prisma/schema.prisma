generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
}

model Location {
  id        String   @id @default(cuid())
  address1  String
  city      String
  state     String
  createdAt DateTime @default(now())
}

model Load {
  id                 String   @id @default(cuid())
  loadNumber         String   @unique
  rate               Float
  pickupLocationId   String
  deliveryLocationId String
  pickupDate         DateTime
  createdById        String

  pickupLocation     Location @relation(fields: [pickupLocationId], references: [id])
  deliveryLocation   Location @relation(fields: [deliveryLocationId], references: [id])

  createdAt          DateTime @default(now())
}
